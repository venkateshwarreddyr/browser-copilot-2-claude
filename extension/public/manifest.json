{
  "manifest_version": 3,
  "name": "Nexus Copilot",
  "version": "0.1.0",
  "description": "AI browser automation copilot powered by Nexus",
  "minimum_chrome_version": "116",
  "permissions": [
    "tabs",
    "storage",
    "activeTab",
    "scripting",
    "sidePanel"
  ],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "assets/background.js",
    "type": "module"
  },
  "action": {
    "default_title": "Nexus Copilot"
  },
  "commands": {
    "toggle-side-panel": {
      "suggested_key": {
        "default": "Ctrl+E",
        "mac": "Command+E"
      },
      "description": "Toggle Nexus Copilot side panel"
    }
  },
  "side_panel": {
    "default_path": "src/sidepanel/index.html"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["assets/content.js"],
      "run_at": "document_idle"
    }
  ]
}
