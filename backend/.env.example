## Provider: HuggingFace (default)
# LLM_BASE_URL=https://router.huggingface.co/v1
# LLM_API_KEY=your-hf-token
# LLM_MODEL=grok-3

## Provider: OpenRouter (Claude, GPT, Grok, etc.)
# LLM_BASE_URL=https://openrouter.ai/api/v1
# LLM_API_KEY=your-openrouter-key
# LLM_MODEL=anthropic/claude-sonnet-4-6

## Provider: OpenAI direct
# LLM_BASE_URL=https://api.openai.com/v1
# LLM_API_KEY=your-openai-key
# LLM_MODEL=gpt-4o

LLM_BASE_URL=https://router.huggingface.co/v1
HF_API_KEY=
HUGGING_FACE_TOKEN=
LLM_API_KEY=
LLM_MODEL=grok-3

# Security
API_SECRET=                           # Required in prod. Clients must send X-API-Key header.
ALLOWED_ORIGINS=chrome-extension://*  # Comma-separated. Leave empty to allow all origins.
MAX_BODY_BYTES=1048576                # 1 MB default
RATE_LIMIT_WINDOW_MS=60000            # 1 minute window (local server only)
RATE_LIMIT_MAX=30                     # Max requests per window per IP (local server only)
